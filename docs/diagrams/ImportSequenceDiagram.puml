@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":ImportCommandParser" as ImportCommandParser LOGIC_COLOR
participant "i:ImportCommand" as ImportCommand LOGIC_COLOR
participant "c:CsvPersonImporter" as CsvPersonImporter LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("import data/sample.csv")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("import data/sample.csv")
activate AddressBookParser

create ImportCommandParser
AddressBookParser -> ImportCommandParser
activate ImportCommandParser

ImportCommandParser --> AddressBookParser
deactivate ImportCommandParser

AddressBookParser -> ImportCommandParser : parse("sample.csv")
activate ImportCommandParser

create ImportCommand
ImportCommandParser -> ImportCommand
activate ImportCommand

create CsvPersonImporter
ImportCommand -> CsvPersonImporter
activate CsvPersonImporter
CsvPersonImporter --> ImportCommand
deactivate CsvPersonImporter

ImportCommand --> ImportCommandParser :
deactivate ImportCommand

ImportCommandParser --> AddressBookParser : i
deactivate ImportCommandParser
'Hidden arrow to position the destroy marker below the end of the activation bar.
ImportCommandParser -[hidden]-> AddressBookParser
destroy ImportCommandParser

AddressBookParser --> LogicManager : i
deactivate AddressBookParser

LogicManager -> ImportCommand : execute(m)
activate ImportCommand

ImportCommand -> CsvPersonImporter : read("sample.csv")
activate CsvPersonImporter

CsvPersonImporter --> ImportCommand : List<Person>
deactivate CsvPersonImporter
loop for all person in List<Person>

ImportCommand -> Model : hasPerson(person)
activate Model
Model --> ImportCommand
deactivate Model
opt model.hasPerson(person) == false
ImportCommand -> Model : addPerson(person)
activate Model
Model --> ImportCommand
deactivate Model
end
end
create CommandResult
ImportCommand -> CommandResult
activate CommandResult

CommandResult --> ImportCommand
deactivate CommandResult

ImportCommand --> LogicManager : r
deactivate ImportCommand

[<--LogicManager
deactivate LogicManager
@enduml
