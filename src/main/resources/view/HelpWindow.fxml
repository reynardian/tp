<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Scene?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.stage.Stage?>

<fx:root resizable="true" title="Help" type="javafx.stage.Stage" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <icons>
    <Image url="@/images/help_icon.png" />
  </icons>
  <scene>
    <Scene>
      <stylesheets>
        <URL value="@HelpWindow.css" />
      </stylesheets>

      <VBox fx:id="helpMessageContainer">
        <children>
          <VBox spacing="8" styleClass="nav-panel">
            <HBox>
              <Hyperlink text="add" onAction="#goToAdd"/>
              <Hyperlink text="delete" onAction="#goToDelete"/>
              <Hyperlink text="list" onAction="#goToList"/>
              <Hyperlink text="remark" onAction="#goToRemark"/>
              <Hyperlink text="find" onAction="#goToFind"/>
            </HBox>
          </VBox>
          <ScrollPane fitToWidth="true" fx:id="scrollPane">
            <content>
              <VBox spacing="6">
                <padding>
                  <Insets top="10" right="15" bottom="10" left="15"/>
                </padding>
                <Label text="Getting Started" styleClass="help-title"/>

                <Separator/>

                <Label fx:id="addSection" text="Add" styleClass="help-section"/>
                <Label text="Command:" styleClass="help-subtitle"/>
                <Label text="add n/STUDENT_NAME a/AGE ad/ADDRESS pn/PARENT_NAME pc/PARENT_PHONE pe/PARENT_EMAIL" styleClass="help-command" wrapText="True"/>
                <Label text="Examples:" styleClass="help-subtitle"/>

                <VBox spacing="2" styleClass="example-box">
                  <padding>
                    <Insets top="10" right="15" bottom="10" left="15"/>
                  </padding>
                  <Label wrapText="True" text="1. add n/James Cook a/12 ad/Blk 132 Edgedale Plains, #15-96 pn/Madison Cook pc/87654321 pe/maddie@gmail.com"/>
                  <Label wrapText="True" text="2. add n/Mary Chew a/7 ad/Blk 123 Bukit Merah Lane, #12-23 pn/Augusta Chew pc/12345678 pe/augusta@email.com t/allergies"/>
                </VBox>

                <Separator/>

                <Label fx:id="deleteSection" text="Delete" styleClass="help-section"/>
                <Label text="Command:" styleClass="help-subtitle"/>
                <Label text="delete INDEX [INDEX]... [START-END]..." styleClass="help-command" wrapText="true"/>

                <Label text="Description:" styleClass="help-subtitle"/>
                <Label text="Deletes one or more students using their index numbers." wrapText="true"/>

                <Label text="Notes:" styleClass="help-subtitle"/>
                <Label text="- Supports bulk deletion by providing multiple indices and/or ranges." wrapText="true"/>
                <Label text="- Ranges are inclusive (e.g. 3-5 deletes indices 3, 4, and 5)." wrapText="true"/>
                <Label text="- You can combine indices and ranges (e.g. 1 3 5-7)." wrapText="true"/>

                <Label text="Examples:" styleClass="help-subtitle"/>
                <VBox spacing="2" styleClass="example-box">
                  <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                  </padding>
                  <Label text="1. delete 1" wrapText="true"/>
                  <Label text="2. delete 3-7" wrapText="true"/>
                  <Label text="2. delete 1 3 5 7-9 10-14" wrapText="true"/>
                </VBox>

                <Separator/>

                <Label fx:id="remarkSection" text="Remark" styleClass="help-section"/>
                <Label text="Command:" styleClass="help-subtitle"/>
                <Label wrapText="true" text="remark INDEX r/[REMARK] d/[DIETARY REMARK] b/[BEHAVIOR REMARK] c/[CLASS]" styleClass="help-command"/>

                <Label text="Description:" styleClass="help-subtitle"/>
                <Label wrapText="true" text="Adds or updates remark fields for the student at the specified index." />

                <Label text="Notes:" styleClass="help-subtitle"/>
                <Label text="- You must provide at least one prefix (r/, d/, c/, or b/)." wrapText="true"/>
                <Label text="- Multiple prefixes can be used to update multiple fields at the same time." wrapText="true"/>
                <Label text="- Existing remarks will be overwritten by the new values." wrapText="true"/>
                <Label text="- To delete a remark, use the prefix with no value (e.g. remark 1 r/)." wrapText="true"/>

                <Label text="Examples:" styleClass="help-subtitle"/>
                <VBox spacing="2" styleClass="example-box">
                  <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                  </padding>
                  <Label text="1. remark 1 r/enjoys sports" wrapText="true"/>
                  <Label text="2. remark 1 d/allergic to shellfish" wrapText="true"/>
                  <Label text="3. remark 1 r/enjoys sports d/allergic to shellfish" wrapText="true"/>
                  <Label text="remark 1 r/enjoys sports d/allergic to shellfish c/1C b/very energetic" wrapText="true"/>
                </VBox>

                <Separator/>

                <Label fx:id="listSection" text="List" styleClass="help-section"/>
                <Label text="Command:" styleClass="help-subtitle"/>
                <Label text="list [n/] | [a/] | [pn/] | [pc/] | [pe/]" styleClass="help-command" wrapText="true"/>

                <Label text="Description:" styleClass="help-subtitle"/>
                <Label text="Displays all students. If a prefix is provided, the list is sorted by that field." wrapText="true"/>

                <Label text="Notes:" styleClass="help-subtitle"/>
                <Label text="- If no prefix is given, students are shown in the default order." wrapText="true"/>
                <Label text="- Only one prefix can be used at a time." wrapText="true"/>
                <Label text="- Alphabetical sort is applied to `n/`, `pn/` and `pe/`." wrapText="true"/>
                <Label text="- Numeric sort in ascending order is applied to `a/` and `pc/`" wrapText="true"/>

                <Label text="Examples:" styleClass="help-subtitle"/>
                <VBox spacing="2" styleClass="example-box">
                  <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                  </padding>
                  <Label text="1. list n/" wrapText="true"/>
                  <Label text="2. list pn/" wrapText="true"/>
                  <Label text="3. list a/" wrapText="true"/>
                </VBox>

                <Separator/>

                <Label fx:id="findSection" text="Find" styleClass="help-section"/>
                <Label text="Command:" styleClass="help-subtitle"/>
                <Label text="find [NAME...] [n/NAME] [a/AGE] [ad/ADDRESS] [t/TAG] [pn/PARENT_NAME] [pc/PARENT_PHONE] [pe/PARENT_EMAIL] [d/DIETARY] [c/CLASS] [b/BEHAVIOR]" styleClass="help-command" wrapText="true"/>

                <Label text="Description:" styleClass="help-subtitle"/>
                <Label text="Filters contacts by one or more fields. Returns contacts that match ANY of the given keywords (OR search). If no prefix is specified (e.g., n/, a/, pn/, pe/), the search will default to student name (n/)." wrapText="true"/>

                <Label text="Notes:" styleClass="help-subtitle"/>
                <Label text="- Multiple parameters can be used (e.g. n/, a/, pn/, pe/)." wrapText="true"/>
                <Label text="- Matches are case-insensitive." wrapText="true"/>
                <Label text="- A contact is shown if it matches at least one condition." wrapText="true"/>
                <Label text="- Use the list command to return to the full list after using find." wrapText="true"/>

                <Label text="Examples:" styleClass="help-subtitle"/>
                <VBox spacing="2" styleClass="example-box">
                  <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                  </padding>
                  <Label text="1. find n/Jane" wrapText="true"/>
                  <Label text="2. find pn/Jane Doe n/Jane" wrapText="true"/>
                  <Label text="3. find a/11" wrapText="true"/>
                </VBox>

              </VBox>
            </content>
          </ScrollPane>
          <Label fx:id="helpMessage" text="Label">
            <padding>
              <Insets top="10" right="5" bottom="10"/>
            </padding>
          </Label>
          <Button fx:id="copyButton" mnemonicParsing="false" onAction="#copyUrl" text="Copy URL">

          </Button>
        </children>
        <opaqueInsets>
          <Insets bottom="10.0" left="5.0" right="10.0" top="5.0" />
        </opaqueInsets>
        <padding>
          <Insets bottom="10.0" left="5.0" right="10.0" top="5.0" />
        </padding>
      </VBox>
    </Scene>
  </scene>
</fx:root>
