<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Scene?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.stage.Stage?>

<fx:root resizable="true" title="Help" type="javafx.stage.Stage" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <icons>
    <Image url="@/images/help_icon.png" />
  </icons>
  <scene>
    <Scene>
      <stylesheets>
        <URL value="@HelpWindow.css" />
      </stylesheets>

      <VBox fx:id="helpMessageContainer">
        <children>
          <VBox spacing="8" styleClass="nav-panel">
            <HBox>
              <Hyperlink text="Add" onAction="#goToAdd"/>
              <Hyperlink text="Delete" onAction="#goToDelete"/>
              <Hyperlink text="List" onAction="#goToList"/>
            </HBox>
            <HBox>
              <Hyperlink text="Add remark" onAction="#goToAddRemark"/>
              <Hyperlink text="Delete remark" onAction="#goToDeleteRemark"/>
              <Hyperlink text="Find by student" onAction="#goToFindStudent"/>
              <Hyperlink text="Find by parent" onAction="#goToFindParent"/>
            </HBox>
          </VBox>
          <ScrollPane fitToWidth="true" fx:id="scrollPane">
            <content>
              <VBox spacing="6">
                <padding>
                  <Insets top="10" right="15" bottom="10" left="15"/>
                </padding>
                <Label text="Getting Started" styleClass="help-title"/>

                <Separator/>

                <Label fx:id="addSection" text="Add a student" styleClass="help-section"/>
                <Label text="Command:" styleClass="help-subtitle"/>
                <Label text="add n/STUDENT_NAME a/AGE ad/ADDRESS pn/PARENT_NAME pc/PARENT_PHONE pe/PARENT_EMAIL" styleClass="help-command" wrapText="True"/>
                <Label text="Examples:" styleClass="help-subtitle"/>

                <VBox spacing="2" styleClass="example-box">
                  <padding>
                    <Insets top="10" right="15" bottom="10" left="15"/>
                  </padding>
                  <Label wrapText="True" text="add n/James Cook a/12 ad/Blk 132 Edgedale Plains, #15-96 pn/Madison Cook pc/87654321 pe/maddie@gmail.com"/>
                  <Label wrapText="True" text="add n/Mary Chew a/7 ad/Blk 123 Bukit Merah Lane, #12-23 pn/Augusta Chew pc/12345678 pe/augusta@email.com t/allergies"/>
                </VBox>

                <Separator/>

                <Label fx:id="deleteSection" text="Delete a student" styleClass="help-section"/>
                <Label text="Command:" styleClass="help-subtitle"/>
                <Label text="delete INDEX" styleClass="help-command"/>
                <Label text="Examples:" styleClass="help-subtitle"/>
                <VBox spacing="2" styleClass="example-box">
                  <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                  </padding>
                  <Label text="delete 1"/>
                  <Label text="delete 3"/>
                </VBox>

                <Separator/>

                <Label fx:id="addRemarkSection" text="Add a remark on a student" styleClass="help-section"/>
                <Label text="Command:" styleClass="help-subtitle"/>
                <Label wrapText="true" text="remark INDEX r/GENERAL_REMARK d/DIETARY_INFORMATION c/CLASS_INFORMATION b/BEHAVIORAL_INFORMATION" styleClass="help-command"/>
                <Label text="Examples:" styleClass="help-subtitle"/>
                <VBox spacing="2" styleClass="example-box">
                  <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                  </padding>
                  <Label text="remark 1 r/enjoys sports"/>
                  <Label text="remark 1 d/allergic to shellfish"/>
                  <Label text="remark 1 r/enjoys sports d/allergic to shellfish"/>
                  <Label wrapText="true" text="remark 1 r/enjoys sports d/allergic to shellfish c/1C b/very energetic"/>
                </VBox>

                <Separator/>

                <Label fx:id="deleteRemarkSection" text="Delete a remark on a student" styleClass="help-section"/>
                <Label text="Command:" styleClass="help-subtitle"/>
                <Label text="delete INDEX r/ d/" styleClass="help-command"/>
                <Label text="Examples:" styleClass="help-subtitle"/>
                <VBox spacing="2" styleClass="example-box">
                  <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                  </padding>
                  <Label text="remark 1 r/"/>
                  <Label text="remark 1 d/"/>
                  <Label text="remark 1 r/ d/"/>
                </VBox>

                <Separator/>

                <Label fx:id="listSection" text="List all students" styleClass="help-section"/>
                <Label text="Command:" styleClass="help-subtitle"/>
                <Label text="list" styleClass="help-command"/>

                <Separator/>

                <Label fx:id="findStudentSection" text="Find by student name" styleClass="help-section"/>
                <Label text="Command:" styleClass="help-subtitle"/>
                <Label text="find n/STUDENT_NAME" styleClass="help-command"/>
                <Label text="Examples:" styleClass="help-subtitle"/>
                <VBox spacing="2" styleClass="example-box">
                  <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                  </padding>
                  <Label text="find n/Jane"/>
                  <Label text="find n/Jane Doe"/>
                </VBox>

                <Separator/>

                <Label fx:id="findParentSection" text="Find by parent name" styleClass="help-section"/>
                <Label text="Command:" styleClass="help-subtitle"/>
                <Label text="find pn/PARENT_NAME" styleClass="help-command"/>
                <VBox spacing="2" styleClass="example-box">
                  <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                  </padding>
                  <Label text="find n/John"/>
                  <Label text="find n/Jonathan Tay Jun Le"/>
                </VBox>

              </VBox>
            </content>
          </ScrollPane>
          <Label fx:id="helpMessage" text="Label">
            <padding>
              <Insets top="10" right="5" bottom="10"/>
            </padding>
          </Label>
          <Button fx:id="copyButton" mnemonicParsing="false" onAction="#copyUrl" text="Copy URL">

          </Button>
        </children>
        <opaqueInsets>
          <Insets bottom="10.0" left="5.0" right="10.0" top="5.0" />
        </opaqueInsets>
        <padding>
          <Insets bottom="10.0" left="5.0" right="10.0" top="5.0" />
        </padding>
      </VBox>
    </Scene>
  </scene>
</fx:root>
